# -*- coding: utf-8 -*-
# Ren'Py project: «Первый день в Японии»
# Акт 1: «Первый день»
#
# Готовый первый акт по сюжету из документа:
# вокзал -> встреча с Акари -> остановка -> автобус -> общежитие -> Сэнсэй.
#
# Артов пока нет, поэтому используются временные цветные фоны и текстовые спрайты.
# Когда будут готовы спрайты и фоны, замените image declarations на файлы из game/images/.

# -------------------------
# Персонажи
# -------------------------

define p = Character("Пётр", color="#9bd5ff")
define a = Character("Акари", color="#ffb3c7")
define s = Character("Сэнсэй", color="#ffd166")
define passerby = Character("Прохожий", color="#c7d2fe")
define announcer = Character("Объявление", color="#d1d5db")

# -------------------------
# Переменные
# -------------------------

default jp_score = 0
default jp_total = 0
default confidence = 0
default akari_trust = 0
default learned_words = []

# -------------------------
# Временные изображения-заглушки
# -------------------------

image bg station_arrival = Solid("#172033")
image bg station_close = Solid("#202b44")
image bg station_exit = Solid("#263447")
image bg bus_evening = Solid("#111827")
image bg dorm_night = Solid("#1f2937")
image bg black_soft = Solid("#0f172a")

image akari neutral = Text("Акари", size=70, color="#ffb3c7", outlines=[(3, "#000000", 0, 0)])
image akari smile = Text("Акари\nулыбается", size=60, color="#ffb3c7", text_align=0.5, outlines=[(3, "#000000", 0, 0)])
image akari teaching = Text("Акари\nобъясняет", size=58, color="#ffb3c7", text_align=0.5, outlines=[(3, "#000000", 0, 0)])
image sensei fox = Text("Сэнсэй\nмаленький\nсветящийся лисёнок", size=42, color="#ffd166", text_align=0.5, outlines=[(3, "#000000", 0, 0)])

# -------------------------
# Позиции
# -------------------------

transform left_side:
    xalign 0.20
    yalign 0.80

transform right_side:
    xalign 0.80
    yalign 0.80

transform center_side:
    xalign 0.50
    yalign 0.80

# -------------------------
# Экраны интерфейса
# -------------------------

screen learning_hud():
    frame:
        xalign 0.02
        yalign 0.03
        background "#00000099"
        padding (14, 10)
        vbox:
            spacing 3
            text "Акт 1: Первый день" size 20 color "#ffffff"
            text "Японский: [jp_score]/[jp_total]" size 18 color "#dbeafe"
            text "Уверенность: [confidence]" size 18 color "#d1d5db"

screen phrase_note(japanese, romaji, meaning):
    frame:
        xalign 0.5
        yalign 0.13
        background "#000000aa"
        padding (22, 14)
        vbox:
            spacing 4
            text japanese size 34 color "#ffffff" xalign 0.5
            text romaji size 24 color "#bfdbfe" xalign 0.5
            text meaning size 22 color "#fde68a" xalign 0.5

# -------------------------
# Служебные label'ы
# -------------------------

label mark_correct:
    $ jp_score += 1
    $ jp_total += 1
    return

label mark_wrong:
    $ jp_total += 1
    return

label learn_word(japanese, romaji, meaning):
    if japanese not in learned_words:
        $ learned_words.append(japanese)
    show screen phrase_note(japanese, romaji, meaning)
    pause 1.0
    hide screen phrase_note
    return

# -------------------------
# Старт игры
# -------------------------

label start:
    $ jp_score = 0
    $ jp_total = 0
    $ confidence = 0
    $ akari_trust = 0
    $ learned_words = []

    scene bg black_soft with fade
    show screen learning_hud

    "Акт 1. Первый день."
    "История начинается в Токио, где семнадцатилетний Пётр Исаев, или просто Петька, впервые оказывается один в чужой стране."
    "Он приехал по школьному обмену."
    "Японский он учил совсем немного. «Аригато», «сайонара» — и то не очень уверенно."
    "Но ему очень хочется справиться самому."
    p "Главное — не паниковать."
    p "Наверное."

    jump act1_scene1_station_lost

# -------------------------
# Сцена 1. Вокзал: потерянность
# -------------------------

label act1_scene1_station_lost:
    scene bg station_arrival with fade

    announcer "次の電車は、まもなく一番線に到着します。"
    "Огромное табло над головой мигает десятками строк."
    "Иероглифы, иероглифы, иероглифы — ни одного знакомого слова."
    "Люди обтекают тебя с двух сторон, как река камень."
    "В руке — смятый листок с адресом общежития."
    "Ты не можешь прочитать его до конца."
    "В кармане — телефон, который отказывается ловить сеть."
    "Ты делаешь глубокий вдох."
    p "Так. С чего начать?"

    menu:
        "Так, спокойно. Наверняка здесь есть информационная стойка.":
            $ confidence += 1
            "Ты отыскиваешь взглядом информационную стойку."
            "Да, она действительно здесь: белая вывеска, очередь из нескольких человек, строгий работник за стойкой."
            "Ты делаешь шаг вперёд."
            "Потом ещё один."
            "А потом замечаешь табличку с формой для обращения — полностью на японском."
            p "Может... сначала подготовиться?"
            "Ты замираешь рядом с потоком людей, так и не решившись подойти."
            "И именно это замечает девушка в нескольких шагах от тебя."

        "Может, просто пойти за всеми? Куда-нибудь да выйду.":
            "Ты выбираешь мужчину в деловом костюме, который выглядит так, будто знает все маршруты мира."
            "Он уверенно идёт к выходу, и ты осторожно следуешь за ним."
            "Первые десять секунд план кажется гениальным."
            "Потом он резко сворачивает к турникетам, достаёт проездную карту и исчезает в толпе."
            p "Ага. Прекрасно. Теперь я потерялся уже увереннее."
            "Ты останавливаешься у колонны."
            "Твой растерянный вид не остаётся незамеченным."

        "Надо найти хоть кого-то, кто говорит по-английски.":
            $ confidence += 1
            p "Excuse me... can you help me?"
            "Первая женщина вежливо улыбается, но, кажется, спешит на поезд."
            p "Sorry, station... school dormitory... address..."
            "Второй прохожий кивает, но отвечает на таком быстром английском, что ты понимаешь только «platform» и «maybe»."
            p "Да уж. Может, мой английский не настолько международный, как я думал."
            "Ты неловко прячешь листок с адресом в карман."
            "Кто-то рядом тихо смеётся — не насмешливо, а будто с пониманием."

    jump act1_scene2_meet_akari

# -------------------------
# Сцена 2. Встреча с Акари
# -------------------------

label act1_scene2_meet_akari:
    scene bg station_close with dissolve
    show akari neutral at right_side with dissolve

    "Девушка встречается с тобой взглядом и улыбается."
    "Не насмешливо. Тепло."
    "Словно она точно знает, что ты чувствуешь."
    "Она делает шаг навстречу."
    a "Привет! Ты выглядишь так, будто только что с самолёта и уже успел потеряться. Я угадала?"
    p "..."

    menu:
        "Да, есть немного... А ты что, говоришь по-русски?":
            $ akari_trust += 1
            p "Да, есть немного... А ты что, говоришь по-русски?"
            show akari smile
            a "Да, говорю. Меня Акари зовут."
            a "Отец у меня из России. Живёт и работает в Токио уже много лет."
            a "А ты смелый — раз один приехал."
            a "Хочешь, покажу, как тут поздороваться?"
            show akari teaching
            a "Смотри: こんにちは — konnichiwa. Это значит «добрый день»."
            call learn_word("こんにちは", "konnichiwa", "добрый день / здравствуйте")

        "こんにちは... а, точнее, здравствуйте!":
            call mark_correct
            $ confidence += 1
            $ akari_trust += 2
            p "こんにちは... а, точнее, здравствуйте!"
            show akari smile
            a "О, так ты уже хотя бы что-то знаешь! Здорово."
            a "Да, я говорю по-русски. Отец из России."
            a "Меня Акари зовут. Давай помогу."
            call learn_word("こんにちは", "konnichiwa", "добрый день / здравствуйте")

        "Просто кивнуть. Пётр слишком растерян, чтобы говорить.":
            "Ты просто киваешь."
            "Слова будто застряли где-то между горлом и чемоданом."
            show akari smile
            a "Понимаю. Первый день в другой стране — это не прогулка."
            a "Я говорю по-русски. Меня Акари зовут."
            a "Давай начнём с простого."
            show akari teaching
            a "こんにちは — konnichiwa. Это значит «добрый день»."
            call learn_word("こんにちは", "konnichiwa", "добрый день / здравствуйте")

    a "Ну-ка, попробуй повторить."
    p "Сейчас..."

    menu:
        "Конничива.":
            call mark_correct
            $ confidence += 1
            p "Конничива."
            show akari smile
            a "Почти идеально!"
            a "Kon-ni-chi-wa — четыре слога, видишь?"
            a "Ты быстро схватываешь."

        "Коннитива.":
            call mark_wrong
            p "Коннитива."
            show akari teaching
            a "Близко!"
            a "Там в серединке не «ти», а «чи» — будто «чи-и-из» говоришь."
            a "И ещё в начале звук «н» длиннее: kon-ni-chi-wa."

        "Коничива.":
            call mark_wrong
            p "Коничива."
            show akari teaching
            a "Почти."
            a "Но в начале не один короткий «н», а как будто два: kon-ni-chi-wa."
            a "Не переживай, ты только начал."

    a "Кстати, куда тебе нужно?"
    p "В школьное общежитие."
    p "По крайней мере, я думаю, что это адрес общежития."
    "Ты протягиваешь ей смятый листок."
    show akari neutral
    "Акари быстро пробегает глазами по строкам."
    show akari smile
    a "О, похоже, мне с тобой в одну школу!"
    p "Правда?"
    a "Правда. Пойдём, провожу."
    a "Заодно по дороге расскажу, что тут и как."
    p "Ты меня сейчас очень спасла."
    a "Тогда пошли, пока автобус не ушёл."

    jump act1_scene3_station_exit

# -------------------------
# Сцена 3. Вокзал — выход к автобусной остановке
# -------------------------

label act1_scene3_station_exit:
    scene bg station_exit with fade
    show akari neutral at right_side

    "Переход к выходу кажется длиннее, чем должен быть."
    "Стеклянные двери впереди отражают вечернее токийское небо."
    "За ними — фонари, вывески, поток машин и ровный городской шум."
    "Акари идёт чуть впереди, но постоянно оборачивается, проверяя, не отстал ли ты."
    a "Не потерялся?"
    p "Пока нет."
    a "Уже прогресс."
    "У выхода она останавливается и показывает куда-то вправо."
    a "Ну вот, автобус до общежития — каждые пятнадцать минут."
    a "Табличку с номером видишь? Это наш."
    "Ты чувствуешь огромную благодарность."
    "Совесть просто не позволит ничего не сказать."

    menu:
        "Аригато... годзаймас тебе, Акари.":
            call mark_wrong
            p "Аригато... годзаймас тебе, Акари."
            show akari teaching
            a "Почти!"
            a "«Годзаймас» звучит так, будто ты уже выдыхаешь в конце."
            a "Надо «годзаймасу» — с лёгким «у»."
            a "arigatou gozaimasu."
            call learn_word("ありがとうございます", "arigatou gozaimasu", "большое спасибо")

        "Спасибо огромное, Акари. Ты меня реально спасла.":
            call mark_wrong
            p "Спасибо огромное, Акари. Ты меня реально спасла."
            show akari smile
            a "Я рада, правда."
            show akari teaching
            a "Но по-русски я и так знаю, что ты благодарен."
            a "Давай попробуем по-японски?"
            a "arigatou gozaimasu — это очень вежливое «большое спасибо»."
            call learn_word("ありがとうございます", "arigatou gozaimasu", "большое спасибо")

        "Аригато годзаймасу, Акари-сан!":
            call mark_correct
            $ confidence += 1
            $ akari_trust += 1
            p "Аригато годзаймасу, Акари-сан!"
            show akari smile
            a "Ух ты, прямо всё правильно сказал!"
            a "И даже «сан» добавил. Очень вежливо."
            a "Я рада, что помогла."
            call learn_word("ありがとうございます", "arigatou gozaimasu", "большое спасибо")

    "Ты делаешь шаг назад, чтобы пропустить женщину с сумками."
    "Колёсико чемодана задевает чей-то велосипед у стойки."
    "Велосипед звякает."
    "Прохожий оборачивается."
    show akari neutral
    a "Ой. Скажи sumimasen — это «извините»."
    call learn_word("すみません", "sumimasen", "извините / простите")

    menu:
        "Сумимасэн!":
            call mark_correct
            $ confidence += 1
            p "Сумимасэн!"
            passerby "..."
            "Прохожий кивает и слегка улыбается."
            show akari smile
            a "Отлично!"
            a "Sumimasen — вообще суперполезное слово."
            a "Им можно и извиниться, и официанта позвать, и внимание привлечь."

        "Простите!":
            call mark_wrong
            p "Простите!"
            passerby "..."
            "Прохожий смотрит на тебя без злости, но явно ничего не понимает."
            show akari teaching
            a "По-русски они не понимают."
            a "Но ничего страшного."
            a "Просто на будущее: sumimasen выручает почти в любой непонятной ситуации."

        "Промолчать.":
            call mark_wrong
            "Ты замираешь."
            "Слова снова исчезают."
            show akari neutral
            "Акари быстро делает небольшой поклон прохожему."
            a "すみません。"
            "Прохожий кивает и уходит."
            show akari teaching
            a "Ничего. В следующий раз попробуешь сам."
            a "Запомни: sumimasen."

    "Через минуту к остановке подъезжает автобус."
    "Двери открываются почти бесшумно."
    a "Поехали."
    a "По дороге расскажу про школу."

    jump act1_scene4_bus_review

# -------------------------
# Сцена 4. Автобус: итоги дня
# -------------------------

label act1_scene4_bus_review:
    scene bg bus_evening with fade
    show akari neutral at right_side

    "Автобус мягко покачивается."
    "За окном проплывают неоновые вывески, окна магазинов и силуэты людей на переходах."
    "Ещё час назад всё это казалось огромным и враждебным."
    "Теперь город всё ещё непонятный, но уже не такой страшный."
    "Акари сидит рядом."
    "Она устала, но улыбается."
    a "Ну что, первый день уже почти позади."
    a "Давай проверим, что у тебя получилось запомнить."
    p "Серьёзно? Прямо сейчас?"
    a "Пока в автобусе. Тут хотя бы никто не оценивает."
    p "Кроме тебя."
    show akari smile
    a "Я не оцениваю. Я поддерживаю."
    show akari teaching
    a "Итак. Как поздороваться по-японски?"

    menu:
        "こんにちは — konnichiwa.":
            call mark_correct
            $ confidence += 1
            p "こんにちは — konnichiwa."
            show akari smile
            a "Да! Добрый день. Отлично."
        "ありがとうございます — arigatou gozaimasu.":
            call mark_wrong
            p "ありがとうございます — arigatou gozaimasu?"
            show akari teaching
            a "Это «большое спасибо»."
            a "А приветствие — こんにちは, konnichiwa."
        "すみません — sumimasen.":
            call mark_wrong
            p "すみません — sumimasen?"
            show akari teaching
            a "Это «извините»."
            a "А чтобы поздороваться, скажи: こんにちは, konnichiwa."

    a "Теперь — как сказать очень вежливое «большое спасибо»?"

    menu:
        "ありがとうございます — arigatou gozaimasu.":
            call mark_correct
            $ confidence += 1
            p "ありがとうございます — arigatou gozaimasu."
            show akari smile
            a "Именно."
            a "Если скажешь так человеку, который тебе помог, это будет очень хорошо."
        "こんにちは — konnichiwa.":
            call mark_wrong
            p "こんにちは — konnichiwa."
            show akari teaching
            a "Это «добрый день»."
            a "Спасибо — arigatou gozaimasu."
        "おやすみ — oyasumi.":
            call mark_wrong
            p "おやすみ — oyasumi."
            show akari neutral
            a "Это «спокойной ночи»."
            a "Хорошее слово, но чуть позже."
            show akari teaching
            a "А спасибо — arigatou gozaimasu."

    a "И последнее на сегодня."
    a "Что сказать, если ты случайно кого-то задел или хочешь извиниться?"

    menu:
        "すみません — sumimasen.":
            call mark_correct
            $ confidence += 1
            p "すみません — sumimasen."
            show akari smile
            a "Да. Самое полезное слово дня."
            a "Если забудешь всё остальное, но запомнишь sumimasen — уже выживешь."
        "はい — hai.":
            call mark_wrong
            p "はい — hai?"
            show akari teaching
            a "Hai — это «да»."
            a "А извиниться можно словом sumimasen."
        "さようなら — sayounara.":
            call mark_wrong
            p "さようなら — sayounara?"
            show akari neutral
            a "Это прощание."
            a "Но если ты задел чей-то велосипед, лучше не прощаться с ним навсегда."
            show akari teaching
            a "Нужно сказать sumimasen."

    "Акари на секунду смотрит в окно."
    a "Знаешь, мой отец когда-то тоже приехал сюда почти без языка."
    p "Правда?"
    a "Да. Он рассказывал, что первые недели чувствовал себя ребёнком."
    a "Не потому что ничего не умел."
    a "А потому что не мог объяснить простые вещи."
    p "Понимаю."
    "Ты сжимаешь ремень рюкзака."
    "Сегодня ты уже зависел от Акари почти во всём."
    "Она помогла, перевела, объяснила, провела."
    "Ты благодарен."
    "Но внутри всё равно тихо царапает мысль: однажды надо справиться самому."
    p "Я хочу научиться."
    show akari smile
    a "Тогда научишься."
    a "Главное — не бояться выглядеть смешно."
    p "С этим, кажется, проблем не будет."
    a "Вот и хорошо."

    "Автобус замедляется."
    "Акари показывает на здание за окном."
    a "Вот мы и на месте."

    jump act1_scene5_dorm_final

# -------------------------
# Сцена 5. Общежитие и Сэнсэй
# -------------------------

label act1_scene5_dorm_final:
    scene bg dorm_night with fade
    show akari smile at right_side

    "Общежитие выглядит спокойно: тёплый свет в окнах, небольшой двор, аккуратная дорожка к входу."
    "После вокзала оно кажется почти островом безопасности."
    a "Завтра увидимся в школе."
    a "Отдохни. Первый день был тяжёлым."
    p "Спасибо. За всё."
    a "Можно по-японски."
    p "Аригато годзаймасу."
    show akari smile
    a "Вот. Уже лучше."
    a "おやすみ — oyasumi. Спокойной ночи."
    call learn_word("おやすみ", "oyasumi", "спокойной ночи")

    hide akari with dissolve

    "Акари уходит к остановке."
    "Ты остаёшься у входа в общежитие один."
    "Токио шумит где-то за спиной, но теперь этот шум не давит так сильно."
    "Ты поднимаешь чемодан на ступеньку."
    "И вдруг в углу зрения появляется мягкое золотистое свечение."

    show sensei fox at left_side with dissolve

    s "Неплохо для первого дня, ученик."
    p "..."
    p "Что?"
    s "Целых три новых слова, несколько ошибок и ни одного побега обратно в аэропорт."
    s "Статистически достойный результат."
    p "Я сейчас разговариваю с маленьким светящимся лисёнком?"
    s "С наставником."
    p "С наставником, который выглядит как маленький светящийся лисёнок."
    s "Форма — лишь оболочка. Но да, оболочка удачная."
    p "Это стресс."
    s "Возможно."
    s "Но даже стресс иногда говорит полезные вещи."
    p "И какие полезные вещи ты скажешь?"
    s "Сегодня ты понял главное: язык — это не только слова."
    s "Это смелость открыть рот, когда страшно ошибиться."
    s "Это благодарность, когда тебе помогли."
    s "И извинение, когда ты задел чужой велосипед."
    p "Звучит как мудрость из дешёвого календаря."
    s "А ты запомнил?"
    p "..."
    p "Запомнил."
    s "Значит, календарь был не так уж плох."
    s "Отдыхай. Завтра будет больше."

    hide sensei with dissolve

    "Свечение исчезает."
    "Ты стоишь несколько секунд, всматриваясь в пустой угол двора."
    p "Ладно."
    p "Галлюцинации от стресса."
    p "В Японии, наверное, и не такое бывает."

    jump act1_results

# -------------------------
# Итоги первого акта
# -------------------------

label act1_results:
    scene bg black_soft with fade
    hide screen learning_hud

    $ percent = 0
    if jp_total > 0:
        $ percent = int((jp_score * 100.0) / jp_total)

    "Акт 1 завершён."
    "Правильных учебных ответов: [jp_score] из [jp_total]."
    "Результат: [percent]%%."

    if percent >= 80:
        "Акари явно впечатлена: для первого дня ты почти не ошибался."
        "Пётр чувствует: может быть, он правда справится."
    elif percent >= 50:
        "Ошибки были, но ты старался."
        "Для первого дня в новой стране это уже победа."
    else:
        "Пока тяжело."
        "Но даже неуверенный шаг — всё равно шаг вперёд."

    "Выученные слова:"
    "こんにちは — konnichiwa — добрый день."
    "ありがとうございます — arigatou gozaimasu — большое спасибо."
    "すみません — sumimasen — извините."
    "おやすみ — oyasumi — спокойной ночи."

    "Продолжение: Акт 2 / Глава 2 «Новые знакомые»."
    "Конец готового первого акта."

    return
